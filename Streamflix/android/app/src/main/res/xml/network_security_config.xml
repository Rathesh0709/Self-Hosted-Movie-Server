<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext HTTP to the LAN / Tailscale streaming backend.
     Mirrors the cleartext hosts from the old capacitor.config.ts. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
